# PostgreSQL connection (use a pooled connection in production)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/alliance_accounting?schema=public"

# Auth.js: generate with `npx auth secret`
AUTH_SECRET="replace-with-at-least-32-random-bytes"
AUTH_TRUST_HOST="true"

# Optional production integrations
S3_BUCKET=""
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
RESEND_API_KEY=""
EMAIL_FROM="Alliance Accounting <portal@example.com>"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Required only when running `npm run db:seed`
SEED_ADMIN_PASSWORD=""
SEED_CLIENT_PASSWORD=""
